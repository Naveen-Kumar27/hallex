{
  "name": "halleyx-dashboard-server",
  "version": "1.0.0",
  "description": "Backend API for Halleyx Custom Dashboard",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "build": "echo 'No build step required for server'",
    "dev": "nodemon src/index.js",
    "kill-port": "powershell -Command \"Stop-Process -Id (Get-NetTCPConnection -LocalPort 5000).OwningProcess -Force -ErrorAction SilentlyContinue; Write-Host 'Port 5000 cleared'\"",
    "fresh": "npm run kill-port && npm run dev"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "@google/generative-ai": "^0.24.1",
    "aws4": "^1.13.2",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.5.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "socket.io": "^4.8.3",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
